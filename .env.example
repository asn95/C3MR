# ── Database ──────────────────────────────────────────────
# Local dev uses SQLite. For production, use PostgreSQL instead.
DATABASE_URL=sqlite:///./c3mr.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Authentication ────────────────────────────────────────
# Use a long, random secret.
JWT_SECRET=change-this-to-a-random-secret

# ── AI Assistant (Anthropic Claude) ───────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
# AGENT_MODEL=claude-haiku-4-5   # optional model override

# ── Telegram Bot & Mini App ───────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
MANAGER_BOT_ALLOWED_IDS=your-telegram-id
MINI_APP_URL=https://your-domain.com/officer-app
WEB_ADMIN_URL=https://your-domain.com

# ── CORS (comma-separated; set to your production domain) ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Debug (set to false in production) ─────────────────────
DEBUG=false
